<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 320 320" role="img" aria-label="10 pôsteres incríveis">
  <defs>
    <radialGradient id="bg" cx="50%" cy="42%" r="60%">
      <stop offset="0%" stop-color="#3a2b00"/>
      <stop offset="70%" stop-color="#120f08"/>
      <stop offset="100%" stop-color="#090808"/>
    </radialGradient>
    <linearGradient id="gold" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#fff1a0"/>
      <stop offset="35%" stop-color="#ffcf2f"/>
      <stop offset="100%" stop-color="#c68a00"/>
    </linearGradient>
  </defs>
  <circle cx="160" cy="160" r="150" fill="url(#bg)"/>
  <circle cx="160" cy="160" r="145" fill="none" stroke="url(#gold)" stroke-width="14"/>
  <circle cx="160" cy="160" r="122" fill="none" stroke="#f1c63b" stroke-width="3" opacity="0.55"/>
  <text x="160" y="136" text-anchor="middle" font-family="Arial Black, Impact, sans-serif" font-size="96" fill="url(#gold)">10</text>
  <text x="160" y="188" text-anchor="middle" font-family="Arial Black, Impact, sans-serif" font-size="42" fill="#ffffff">PÔSTERES</text>
  <text x="160" y="232" text-anchor="middle" font-family="Arial Black, Impact, sans-serif" font-size="40" fill="#ffffff">INCRÍVEIS</text>
</svg>